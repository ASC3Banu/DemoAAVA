# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_DIR=logs

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logistics_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_SSL_CA=
DB_SSL_KEY=
DB_SSL_CERT=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_CA=
REDIS_TLS_KEY=
REDIS_TLS_CERT=

# Kafka
KAFKA_CLIENT_ID=logistics-monitoring-system
KAFKA_BROKERS=localhost:9092
KAFKA_SSL_CA=
KAFKA_SSL_KEY=
KAFKA_SSL_CERT=
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_AUDIT_ENABLED=true

# Authentication (JWT)
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=logistics-monitoring-system
JWT_AUDIENCE=logistics-api

# OAuth 2.0
OAUTH_AUTH_URL=
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=

# Multi-Factor Authentication
MFA_ENABLED=true
MFA_ISSUER=Logistics Monitoring

# Session
SESSION_SECRET=your_session_secret_here_min_32_chars

# Encryption (AES-256)
ENCRYPTION_MASTER_KEY=your_encryption_key_here_64_hex_chars
KEY_ROTATION_ENABLED=true
KEY_ROTATION_INTERVAL=90

# TLS/SSL
TLS_ENABLED=true
TLS_KEY_PATH=/path/to/private-key.pem
TLS_CERT_PATH=/path/to/certificate.pem
TLS_CA_PATH=/path/to/ca-certificate.pem

# CORS
CORS_WHITELIST=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# External Services
CARRIER_API_BASE_URL=
CARRIER_API_KEY=
AI_PREDICTION_API_URL=
AI_PREDICTION_API_KEY=
NOTIFICATION_SERVICE_URL=
NOTIFICATION_SERVICE_KEY=

# Monitoring & Observability
APM_ENABLED=false
APM_SERVICE_NAME=logistics-monitoring-api
APM_SERVER_URL=
APM_SECRET_TOKEN=

# Compliance
DATA_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=3650
GDPR_ENABLED=true
PCI_DSS_ENABLED=true

# Feature Flags
FEATURE_AI_PREDICTIONS=true
FEATURE_REAL_TIME_TRACKING=true
FEATURE_WEBHOOKS=true