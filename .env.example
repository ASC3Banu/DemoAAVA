# Application
NODE_ENV=development
PORT=3000
APP_NAME=Logistics Monitoring System
API_VERSION=v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=logistics_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# InfluxDB (Time-Series Data)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-token
INFLUX_ORG=logistics
INFLUX_BUCKET=events

# Kafka Message Queue
KAFKA_BROKERS=localhost:9092
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL=false
KAFKA_CONSUMER_GROUP=logistics-consumer-group

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
SALT=your-salt-for-password-hashing

# Rate Limiting
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Security
SESSION_SECRET=your-session-secret
CSRF_PROTECTION=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=info

# Cache TTL (seconds)
CACHE_TTL=300

# AI/ML Services
AI_PREDICTION_ENDPOINT=http://localhost:5000/predict
AI_ANOMALY_ENDPOINT=http://localhost:5000/anomaly